# Loom configuration — place as .github/loom.yml in your repo.
# All fields are optional; defaults are shown.

# Override auto-detected repo (useful for forks)
# repo: "owner/repo"

branches:
  base: "dev"           # base branch for feature branches
  release: "main"       # release branch
  types:                # allowed branch type prefixes
    - feat
    - fix
    - doc
    - refactor
    - issue

# Merge strategy: merge, squash, rebase (default: merge)
# merge_method: "squash"

# CI status checks required for branch protection (used by setup tool)
# checks:
#   - "build (linux, amd64)"
#   - vet
#   - test
